{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "BrickLayer: Daily Version Check",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/version-check.sh",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "echo": false,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
