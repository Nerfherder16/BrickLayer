# Normalize line endings: store as LF in repo, checkout as-is (no CRLF conversion)
# Prevents masonry hook .js files from flipping LF↔CRLF on every git touch (autocrlf=true)

* text=auto eol=lf
*.js eol=lf
*.ts eol=lf
*.json eol=lf
*.md text eol=lf
*.py eol=lf
*.sh eol=lf

# Windows-specific scripts (keep CRLF)
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf
