## Rust Patterns

```rust
// Error handling — use thiserror for library errors
#[derive(Debug, thiserror::Error)]
pub enum RecallError {
    #[error("memory not found: {id}")]
    NotFound { id: String },
    #[error("database error: {0}")]
    Db(#[from] sqlx::Error),
}

// Async service pattern with tokio
pub struct MemoryStore {
    db: sqlx::SqlitePool,
}

impl MemoryStore {
    pub async fn get(&self, id: &str) -> Result<Memory, RecallError> {
        sqlx::query_as!(Memory, "SELECT * FROM memories WHERE id = ?", id)
            .fetch_optional(&self.db)
            .await?
            .ok_or_else(|| RecallError::NotFound { id: id.to_string() })
    }
}

// Clippy — always clean
// cargo clippy -- -D warnings
// Prefer: for (i, item) in items.iter().enumerate() over manual index loops
// Prefer: #[derive(Default)] over impl Default when Default variant is obvious
```

