#!/usr/bin/env python3
"""
fix_recall_instructions.py
Convert recall_store/recall_search code blocks in agent .md files to
imperative tool-call instructions so agents actually execute them.

Before:
  ```
  recall_store(
      content="...",
      memory_type="semantic",
      ...
  )
  ```

After:
  Use **`mcp__recall__recall_store`**:
  - `content`: "..."
  - `memory_type`: "semantic"
  - ...
"""

import re
import pathlib


def split_top_level_commas(s):
    """Split a kwarg string on top-level commas only (respects nesting and strings)."""
    parts = []
    depth = 0
    cur = []
    in_str = None
    i = 0
    while i < len(s):
        ch = s[i]
        if in_str:
            cur.append(ch)
            if ch == '\\':
                i += 1
                if i < len(s):
                    cur.append(s[i])
            elif ch == in_str:
                in_str = None
        elif ch in ('"', "'"):
            in_str = ch
            cur.append(ch)
        elif ch in ('(', '[', '{'):
            depth += 1
            cur.append(ch)
        elif ch in (')', ']', '}'):
            depth -= 1
            cur.append(ch)
        elif ch == ',' and depth == 0:
            parts.append(''.join(cur).strip())
            cur = []
        else:
            cur.append(ch)
        i += 1
    if cur:
        parts.append(''.join(cur).strip())
    return [p for p in parts if p]


def parse_call_to_bullets(call_text):
    """Convert a recall_store/recall_search(...) call to imperative bullet format."""
    call_text = call_text.strip()

    if call_text.startswith('recall_store'):
        mcp_tool = 'mcp__recall__recall_store'
    elif call_text.startswith('recall_search'):
        mcp_tool = 'mcp__recall__recall_search'
    else:
        return None

    # Find balanced parens
    start = call_text.index('(')
    depth = 0
    end = -1
    in_str = None
    i = start
    while i < len(call_text):
        ch = call_text[i]
        if in_str:
            if ch == '\\':
                i += 2
                continue
            if ch == in_str:
                in_str = None
        elif ch in ('"', "'"):
            in_str = ch
        elif ch == '(':
            depth += 1
        elif ch == ')':
            depth -= 1
            if depth == 0:
                end = i
                break
        i += 1

    if end == -1:
        return None

    args_str = call_text[start + 1:end].strip()
    if not args_str:
        return None

    params = {}
    for part in split_top_level_commas(args_str):
        if '=' in part:
            k, _, v = part.partition('=')
            params[k.strip()] = v.strip()

    if not params:
        return None

    lines = [f'Use **`{mcp_tool}`**:']
    for k, v in params.items():
        lines.append(f'- `{k}`: {v}')

    return '\n'.join(lines)


_OPEN_PLAIN = re.compile(r'^```\s*$')  # opening fence with no language tag
_CLOSE_FENCE = re.compile(r'^```\s*$')  # closing fence (same pattern)


def block_has_only_recall_calls(body):
    """Return True if block body is entirely recall_store/recall_search calls."""
    stripped = body.strip()
    if not stripped:
        return False
    return bool(re.match(r'^recall_(?:store|search)\b', stripped))


def replace_block(m):
    body = m.group(1)
    if not block_has_only_recall_calls(body):
        return m.group(0)

    # A block may contain multiple consecutive recall_ calls
    # Split on lines that begin a new recall_ call
    chunks = re.split(r'(?=recall_(?:store|search)\()', body.strip())
    chunks = [c.strip() for c in chunks if c.strip()]

    results = []
    for chunk in chunks:
        bullet = parse_call_to_bullets(chunk)
        if bullet is None:
            return m.group(0)  # can't parse — leave unchanged
        results.append(bullet)

    return '\n\n'.join(results)


def transform_file(path):
    """Parse lines to find plain ``` blocks, replace recall-only blocks in-place."""
    path = pathlib.Path(path)
    original = path.read_text(encoding='utf-8')
    lines = original.splitlines(keepends=True)

    out = []
    i = 0
    blocks_converted = 0
    in_lang_block = False  # inside a ```lang ... ``` block

    while i < len(lines):
        line = lines[i]
        stripped = line.rstrip('\r\n')

        # Track language-tagged blocks so we don't confuse their closing ``` with an opener
        if not in_lang_block and re.match(r'^```\S', stripped):
            in_lang_block = True
            out.append(line)
            i += 1
            continue

        if in_lang_block:
            out.append(line)
            if stripped == '```':
                in_lang_block = False
            i += 1
            continue

        # Plain opening fence?
        if stripped == '```':
            # Collect body lines until the matching closing fence
            body_lines = []
            j = i + 1
            while j < len(lines):
                bline = lines[j].rstrip('\r\n')
                if bline == '```':
                    break
                body_lines.append(lines[j])
                j += 1

            body = ''.join(body_lines)
            if block_has_only_recall_calls(body) and j < len(lines):
                replacement = replace_block_body(body)
                if replacement is not None:
                    # Emit replacement (no surrounding fences)
                    out.append(replacement + '\n')
                    blocks_converted += 1
                    i = j + 1  # skip opening fence, body, closing fence
                    continue

            # Not a recall block or couldn't parse — emit unchanged
            out.append(line)
            i += 1
            continue

        out.append(line)
        i += 1

    updated = ''.join(out)
    if updated != original:
        path.write_text(updated, encoding='utf-8')
        return blocks_converted or 1
    return 0


def main():
    agents_dir = pathlib.Path('template/.claude/agents')
    files = sorted(agents_dir.glob('*.md'))

    total_files = 0
    total_blocks = 0
    for f in files:
        n = transform_file(f)
        if n:
            total_files += 1
            total_blocks += n
            print(f'  {f.name}: {n} block(s) converted')

    print(f'\nDone: {total_files} files, ~{total_blocks} code blocks converted to imperative instructions.')


if __name__ == '__main__':
    main()
