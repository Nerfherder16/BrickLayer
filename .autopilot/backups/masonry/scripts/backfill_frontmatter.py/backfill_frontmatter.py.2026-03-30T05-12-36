"""Backfill YAML frontmatter on agent .md files missing it.

Reads each agent .md file, detects if YAML frontmatter exists, and if not,
generates minimal frontmatter from the filename and any existing body content.

Idempotent — running twice produces the same result.

Usage:
    python masonry/scripts/backfill_frontmatter.py [--agents-dir PATH]
"""

from __future__ import annotations

import argparse
import sys
from pathlib import Path

import yaml

_SKIP_STEMS = frozenset({"SCHEMA", "AGENTS", "README", "INDEX", "AUDIT_REPORT"})

_DEFAULT_AGENTS_DIR = Path(".claude/agents")


def should_backfill(path: Path) -> bool:
    """Return True if the file is an agent .md that needs frontmatter."""
    if path.stem.upper() in _SKIP_STEMS:
        return False
    if not path.suffix == ".md":
        return False
    content = path.read_text(encoding="utf-8").strip()
    return not content.startswith("---")


def _extract_description(body: str, stem: str) -> str:
    """Extract a description from body text, or generate from stem."""
    # Strip markdown heading if first line
    lines = [l for l in body.strip().splitlines() if l.strip()]

    for line in lines:
        # Skip markdown headings entirely — they're titles, not descriptions
        if line.strip().startswith("#"):
            continue
        cleaned = line.strip()
        # Skip "STUB" or very short lines
        if len(cleaned) < 20:
            continue
        # Use first meaningful paragraph line as description
        return cleaned

    # Fallback: generate from stem
    human_name = stem.replace("-", " ").replace("_", " ")
    return f"Specialist agent for {human_name} tasks."


def backfill_file(path: Path) -> bool:
    """Add YAML frontmatter to an agent file if missing.

    Returns True if frontmatter was added, False if already present.
    """
    content = path.read_text(encoding="utf-8")

    if content.strip().startswith("---"):
        return False

    stem = path.stem
    body = content.strip()
    description = _extract_description(body, stem)

    frontmatter = {
        "name": stem,
        "description": description,
        "model": "sonnet",
        "tier": "draft",
        "modes": [],
        "capabilities": [],
        "tools": [],
    }

    fm_str = yaml.dump(frontmatter, default_flow_style=False, sort_keys=False).rstrip()
    if body:
        new_content = f"---\n{fm_str}\n---\n{body}\n"
    else:
        new_content = f"---\n{fm_str}\n---\n"

    path.write_text(new_content, encoding="utf-8")
    return True


def backfill_directory(agents_dir: Path) -> dict[str, int]:
    """Backfill all agent files in a directory.

    Returns dict with 'updated' and 'skipped' counts.
    """
    updated = 0
    skipped = 0

    for md_file in sorted(agents_dir.glob("*.md")):
        if not should_backfill(md_file):
            skipped += 1
            continue
        if backfill_file(md_file):
            updated += 1
            print(f"  [backfill] Added frontmatter: {md_file.name}", file=sys.stderr)
        else:
            skipped += 1

    return {"updated": updated, "skipped": skipped}


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Backfill YAML frontmatter on agent .md files."
    )
    parser.add_argument(
        "--agents-dir",
        default=str(_DEFAULT_AGENTS_DIR),
        help=f"Directory containing agent .md files. Default: {_DEFAULT_AGENTS_DIR}",
    )
    args = parser.parse_args()
    agents_dir = Path(args.agents_dir)

    if not agents_dir.is_dir():
        print(f"Error: {agents_dir} is not a directory", file=sys.stderr)
        sys.exit(1)

    result = backfill_directory(agents_dir)
    print(
        f"Backfill complete: {result['updated']} updated, {result['skipped']} skipped"
    )


if __name__ == "__main__":
    main()
