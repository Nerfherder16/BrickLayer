"""
Tests for backfill_keywords_extractor.py (extraction strategies unit tests).

More extensive integration tests are in test_backfill_routing_keywords.py.
"""
import sys
from pathlib import Path

SCRIPTS_DIR = Path(__file__).parent.parent / "scripts"
sys.path.insert(0, str(SCRIPTS_DIR))

from backfill_keywords_extractor import (
    strategy_quoted,
    strategy_capabilities,
    strategy_body_sections,
    extract_keywords,
    MIN_PHRASE_LEN,
    MAX_PHRASE_LEN,
    MAX_KEYWORDS,
)


def test_strategy_quoted_extracts_double_quoted():
    result = strategy_quoted("Use this for 'blast radius analysis'")
    assert "blast radius analysis" in result


def test_strategy_quoted_extracts_single_quoted():
    result = strategy_quoted('Use this for "cascade mapping"')
    assert "cascade mapping" in result


def test_strategy_quoted_min_length_enforced():
    # 4-char phrase — below the regex minimum of 5
    result = strategy_quoted("'ab cd'")
    assert result == []


def test_strategy_quoted_max_length_enforced():
    long_phrase = "x" * 51
    result = strategy_quoted(f"'{long_phrase}'")
    assert result == []


def test_strategy_capabilities_extracts_list_items():
    caps = ["failure cascade", "blast radius", "propagation risk"]
    result = strategy_capabilities(caps)
    assert "failure cascade" in result
    assert "blast radius" in result


def test_strategy_capabilities_non_list_returns_empty():
    assert strategy_capabilities(None) == []
    assert strategy_capabilities("string") == []
    assert strategy_capabilities(42) == []


def test_strategy_capabilities_short_items_filtered():
    # MIN_PHRASE_LEN = 3, items with len < 3 after cleaning should be filtered
    result = strategy_capabilities(["ab", "ok item here"])
    assert "ab" not in result
    assert "ok item here" in result


def test_strategy_body_sections_when_to_invoke():
    body = "\n## When to invoke\nUse for latency measurement tasks. Extra sentence."
    result = strategy_body_sections(body)
    assert any("latency measurement" in r for r in result)


def test_strategy_body_sections_use_for():
    body = "\n## Use for\nPerformance benchmarking and throughput analysis."
    result = strategy_body_sections(body)
    assert len(result) >= 1


def test_strategy_body_sections_trigger():
    body = "\n## Trigger\nWhen real measurements are needed."
    result = strategy_body_sections(body)
    assert len(result) >= 1


def test_strategy_body_sections_activate_when():
    body = "\n## Activate when\nSystem is working and user wants improvements."
    result = strategy_body_sections(body)
    assert len(result) >= 1


def test_strategy_body_sections_no_heading():
    body = "No relevant heading. Just normal text."
    assert strategy_body_sections(body) == []


def test_extract_keywords_combines_strategies():
    fm = {
        "description": "'cascade analysis'",
        "capabilities": ["blast radius"],
    }
    body = "\n## When to invoke\nUse when mapping failure cascades."
    kws, source = extract_keywords(fm, body)
    assert len(kws) > 0
    assert "quoted" in source or "capabilities" in source or "body_sections" in source


def test_extract_keywords_respects_max():
    fm = {"capabilities": [f"keyword number {i:02d}" for i in range(20)]}
    kws, _ = extract_keywords(fm, "")
    assert len(kws) <= MAX_KEYWORDS


def test_extract_keywords_deduplication():
    fm = {
        "description": "'shared phrase'",
        "capabilities": ["shared phrase", "unique item"],
    }
    kws, _ = extract_keywords(fm, "")
    assert kws.count("shared phrase") == 1


def test_extract_keywords_sorted_by_length():
    fm = {"capabilities": ["long capability name", "short", "medium len"]}
    kws, _ = extract_keywords(fm, "")
    lengths = [len(k) for k in kws]
    assert lengths == sorted(lengths)


def test_extract_keywords_empty_returns_none_source():
    kws, source = extract_keywords({}, "")
    assert kws == []
    assert source == "none"
