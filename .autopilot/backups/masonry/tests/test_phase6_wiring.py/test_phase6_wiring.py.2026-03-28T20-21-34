# P6H — Phase 6 Hooks
# ═══════════════════════════════════════════════════════════════════════════════

PHASE6_HOOKS = [
    "masonry-config-protection.js",
    "masonry-block-no-verify.js",
    "masonry-pre-compact.js",
]


class TestPhase6Hooks:

    @pytest.mark.parametrize("hook_name", PHASE6_HOOKS)
    def test_p6h_hook_file_exists(self, hook_name):
        """Each Phase 6 hook .js file exists in masonry/src/hooks/."""
        path = HOOKS_DIR / hook_name
        assert path.exists(), (
            f"Phase 6 hook missing: {path}\n"
            f"Fix: create {hook_name} in masonry/src/hooks/"
        )

    @pytest.mark.parametrize("hook_name", PHASE6_HOOKS)
    def test_p6h_hook_registered_in_settings(self, hook_name):
        """Each Phase 6 hook is referenced in settings.json."""
        commands = _settings_commands()
        registered = any(hook_name in cmd for cmd in commands)
        assert registered, (
            f"Phase 6 hook not registered in settings.json: {hook_name}\n"
            f"Fix: add to appropriate event in settings.json"
        )


