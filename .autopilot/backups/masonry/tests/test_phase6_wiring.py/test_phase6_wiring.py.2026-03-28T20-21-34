"""
Phase 6 Wiring Tests
====================
Targeted coverage for Phase 6 additions: new agents, hooks, and skills.

Run: pytest masonry/tests/test_phase6_wiring.py -v

Categories:
  P6A  Phase 6 agents — file exists + required frontmatter fields
  P6H  Phase 6 hooks — file exists + registered in settings.json
  P6S  Phase 6 skills — SKILL.md exists
"""

import json
from pathlib import Path

import pytest

# ── Roots ────────────────────────────────────────────────────────────────────
REPO = Path("C:/Users/trg16/Dev/Bricklayer2.0")
CLAUDE = Path("C:/Users/trg16/.claude")
HOOKS_DIR = REPO / "masonry/src/hooks"
SETTINGS = CLAUDE / "settings.json"
GLOBAL_AGENTS = CLAUDE / "agents"
GLOBAL_SKILLS = CLAUDE / "skills"


def _read(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="ignore")


def _settings_commands() -> set[str]:
    """Return all hook command strings from settings.json."""
    settings = json.loads(_read(SETTINGS))
    commands = set()
    for event_hooks in settings.get("hooks", {}).values():
        for group in event_hooks:
            for hook in group.get("hooks", []):
                cmd = hook.get("command", "")
                if cmd:
                    commands.add(cmd)
    return commands


def _agent_has_field(path: Path, field: str) -> bool:
    """Return True if the agent frontmatter contains the given field key."""
    text = _read(path)
    if not text.startswith("---"):
        return False
    end = text.find("---", 3)
    if end == -1:
        return False
    fm = text[3:end]
    return f"{field}:" in fm


# ═══════════════════════════════════════════════════════════════════════════════
# P6A — Phase 6 Agents
# ═══════════════════════════════════════════════════════════════════════════════

PHASE6_AGENTS = [
    "spec-reviewer",
    "verification-analyst",
    "mcp-developer",
    "chaos-engineer",
    "penetration-tester",
    "scientific-literature-researcher",
]

PHASE6_AGENT_REQUIRED_FIELDS = {
    "spec-reviewer": ["name", "description", "tools"],
    "verification-analyst": ["name", "description"],
    "mcp-developer": ["name", "description"],
    "chaos-engineer": ["name", "description"],
    "penetration-tester": ["name", "description"],
    "scientific-literature-researcher": ["name", "description"],
}


class TestPhase6Agents:

    @pytest.mark.parametrize("agent_name", PHASE6_AGENTS)
    def test_p6a_agent_file_exists(self, agent_name):
        """Each Phase 6 agent .md file exists in ~/.claude/agents/."""
        path = GLOBAL_AGENTS / f"{agent_name}.md"
        assert path.exists(), (
            f"Phase 6 agent missing: {path}\n"
            f"Fix: create {agent_name}.md in ~/.claude/agents/"
        )

    @pytest.mark.parametrize("agent_name", PHASE6_AGENTS)
    def test_p6a_agent_has_frontmatter(self, agent_name):
        """Each Phase 6 agent .md file starts with YAML frontmatter (---)."""
        path = GLOBAL_AGENTS / f"{agent_name}.md"
        if not path.exists():
            pytest.skip(f"{agent_name}.md missing — caught by existence test")
        text = _read(path).strip()
        assert text.startswith("---"), (
            f"{agent_name}.md missing YAML frontmatter\n"
            f"Fix: add ---\\nname: ...\\ndescription: ...\\n--- at top"
        )

    @pytest.mark.parametrize("agent_name", PHASE6_AGENTS)
    def test_p6a_agent_required_fields(self, agent_name):
        """Each Phase 6 agent has required frontmatter fields."""
        path = GLOBAL_AGENTS / f"{agent_name}.md"
        if not path.exists():
            pytest.skip(f"{agent_name}.md missing — caught by existence test")
        required = PHASE6_AGENT_REQUIRED_FIELDS.get(agent_name, ["name", "description"])
        missing_fields = [
            field for field in required
            if not _agent_has_field(path, field)
        ]
        assert not missing_fields, (
            f"{agent_name}.md missing frontmatter fields: {missing_fields}\n"
            f"Fix: add missing fields to frontmatter block"
        )


