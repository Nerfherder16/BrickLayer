CLAUDE = Path("C:/Users/trg16/.claude")
TEMPLATE_AGENTS = REPO / "template/.claude/agents"
TEMPLATE_SKILLS = REPO / "template/.claude/skills"
GLOBAL_AGENTS = CLAUDE / "agents"
GLOBAL_SKILLS = CLAUDE / "skills"
MASONRY = REPO / "masonry"


def _read(path: Path) -> str:
    return path.read_text(encoding="utf-8", errors="ignore")


def _has(path: Path, *patterns: str) -> None:
    text = _read(path)
    for p in patterns:
        assert re.search(p, text, re.IGNORECASE | re.MULTILINE), f"Pattern not found in {path.name}: {p!r}"


