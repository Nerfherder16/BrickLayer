import { describe, it, expect, beforeEach } from 'vitest';
import path from 'path';

describe('engine/tmux/helpers — MODEL_MAP', () => {
  let helpers;

  beforeEach(() => {
    const modPath = path.resolve(process.cwd(), 'src', 'engine', 'tmux', 'helpers.js');
    delete require.cache[modPath];
    helpers = require(modPath);
  });

  it('should export MODEL_MAP with opus, sonnet, haiku', () => {
    expect(helpers.MODEL_MAP).toEqual({
      opus: 'claude-opus-4-6',
      sonnet: 'claude-sonnet-4-6',
      haiku: 'claude-haiku-4-5-20251001',
    });
  });
});

describe('engine/tmux/helpers — resolveModel', () => {
  let helpers;

  beforeEach(() => {
    const modPath = path.resolve(process.cwd(), 'src', 'engine', 'tmux', 'helpers.js');
    delete require.cache[modPath];
    helpers = require(modPath);
  });

  it('should map short name to full model ID', () => {
    expect(helpers.resolveModel('opus')).toBe('claude-opus-4-6');
    expect(helpers.resolveModel('sonnet')).toBe('claude-sonnet-4-6');
    expect(helpers.resolveModel('haiku')).toBe('claude-haiku-4-5-20251001');
  });

  it('should pass through unknown model names', () => {
    expect(helpers.resolveModel('claude-custom-model')).toBe('claude-custom-model');
  });

  it('should return null for null or empty', () => {
    expect(helpers.resolveModel(null)).toBeNull();
    expect(helpers.resolveModel('')).toBeNull();
    expect(helpers.resolveModel(undefined)).toBeNull();
  });
});

describe('engine/tmux/helpers — buildEnv', () => {
  let helpers, origEnv;

  beforeEach(() => {
    const modPath = path.resolve(process.cwd(), 'src', 'engine', 'tmux', 'helpers.js');
    delete require.cache[modPath];
    helpers = require(modPath);
    origEnv = { ...process.env };
  });

  afterEach(() => {
    process.env = origEnv;
  });

  it('should exclude CLAUDECODE from env', () => {
    process.env.CLAUDECODE = 'yes';
    const env = helpers.buildEnv();
    expect(env.CLAUDECODE).toBeUndefined();
  });

  it('should apply env overrides', () => {
    const env = helpers.buildEnv({ MY_VAR: 'hello' });
    expect(env.MY_VAR).toBe('hello');
  });

  it('should remove env var when override is empty string', () => {
    process.env.REMOVE_ME = 'exists';
    const env = helpers.buildEnv({ REMOVE_ME: '' });
    expect(env.REMOVE_ME).toBeUndefined();
  });

  it('should return copy of process.env without CLAUDECODE when no overrides', () => {
    process.env.CLAUDECODE = 'yes';
    process.env.KEEP_ME = 'stay';
    const env = helpers.buildEnv();
    expect(env.KEEP_ME).toBe('stay');
    expect(env.CLAUDECODE).toBeUndefined();
  });
});

describe('engine/tmux/helpers — buildClaudeArgs', () => {
  let helpers;

  beforeEach(() => {
    const modPath = path.resolve(process.cwd(), 'src', 'engine', 'tmux', 'helpers.js');
    delete require.cache[modPath];
    helpers = require(modPath);
  });

  it('should return base args with default json output', () => {
    const args = helpers.buildClaudeArgs({});
    expect(args).toContain('-p');
    expect(args).toContain('-');
    expect(args).toContain('--output-format');
    expect(args).toContain('json');
  });

  it('should include model when provided', () => {
    const args = helpers.buildClaudeArgs({ model: 'opus' });
    expect(args).toContain('--model');
    expect(args).toContain('claude-opus-4-6');
  });

  it('should include allowed and disallowed tools', () => {
    const args = helpers.buildClaudeArgs({
      allowedTools: ['Bash', 'Read'],
      disallowedTools: ['Write'],
    });
    expect(args).toContain('--allowedTools');
    expect(args).toContain('Bash,Read');
    expect(args).toContain('--disallowedTools');
    expect(args).toContain('Write');
  });

  it('should include --dangerously-skip-permissions when set', () => {
    const args = helpers.buildClaudeArgs({ dangerouslySkipPermissions: true });
    expect(args).toContain('--dangerously-skip-permissions');
  });

  it('should include --resume with session ID', () => {
    const args = helpers.buildClaudeArgs({ sessionId: 'abc123' });
    expect(args).toContain('--resume');
    expect(args).toContain('abc123');
  });

  it('should omit --output-format when outputFormat is null', () => {
    const args = helpers.buildClaudeArgs({ outputFormat: null });
    expect(args).not.toContain('--output-format');
  });
});

describe('engine/tmux/helpers — extractSessionId', () => {
  let helpers;

  beforeEach(() => {
    const modPath = path.resolve(process.cwd(), 'src', 'engine', 'tmux', 'helpers.js');
    delete require.cache[modPath];
    helpers = require(modPath);
  });

  it('should extract session_id from valid JSON', () => {
    const raw = JSON.stringify({ session_id: 'sess-abc123', result: 'ok' });
    expect(helpers.extractSessionId(raw)).toBe('sess-abc123');
  });

  it('should return null for JSON without session_id', () => {
    expect(helpers.extractSessionId(JSON.stringify({ result: 'ok' }))).toBeNull();
  });

  it('should return null for invalid JSON', () => {
    expect(helpers.extractSessionId('not json')).toBeNull();
  });

  it('should return null for empty or null input', () => {
    expect(helpers.extractSessionId('')).toBeNull();
    expect(helpers.extractSessionId(null)).toBeNull();
  });
});
