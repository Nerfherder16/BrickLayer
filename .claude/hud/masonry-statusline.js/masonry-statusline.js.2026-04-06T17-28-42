"use strict";
const fs = require("fs");
const path = require("path");
const os = require("os");
const { spawn, execSync } = require("child_process");

const C = {
  purple: "\x1b[38;2;139;92;246m",
  cyan: "\x1b[38;2;34;211;238m",
  orange: "\x1b[38;2;251;146;60m",
  pink: "\x1b[38;2;244;114;182m",
  green: "\x1b[38;2;52;211;153m",
  amber: "\x1b[38;2;245;158;11m",
  red: "\x1b[38;2;239;68;68m",
  dim: "\x1b[2m",
  reset: "\x1b[0m",
};
const c = (col, txt) => `${C[col]}${txt}${C.reset}`;
const dim = (txt) => `${C.dim}${txt}${C.reset}`;
const sep = dim("│");

function progressBar(pct) {
  const filled = Math.round((pct / 100) * 10);
  const col = pct >= 65 ? "pink" : pct >= 40 ? "orange" : "purple";
  return c(col, "█".repeat(filled)) + dim("░".repeat(10 - filled));
}

function loadConfig() {
  const DEFAULTS = {
    recallHost: process.env.RECALL_HOST || "http://100.70.195.84:8200",
    recallApiKey: process.env.RECALL_API_KEY || "",
    handoffThreshold: 70,
  };
  try {
    const p = path.join(os.homedir(), ".masonry", "config.json");
    if (fs.existsSync(p))
      return {
        ...DEFAULTS,
        ...JSON.parse(fs.readFileSync(p, "utf8")),
        recallApiKey: process.env.RECALL_API_KEY || "",
      };
  } catch (_) {}
  return DEFAULTS;
}

function recallDot(cfg) {
  const cacheFile = path.join(os.tmpdir(), "masonry-recall-status.json");
  try {
    if (fs.existsSync(cacheFile)) {
      const d = JSON.parse(fs.readFileSync(cacheFile, "utf8"));
      if (Date.now() - (d.ts || 0) < 30000)
        return d.ok ? c("green", "●") : c("red", "●");
    }
  } catch (_) {}
  // Spawn background check
  try {
    const script = path.join(os.homedir(), ".claude", "hud", "masonry-recall-check.js");
    if (fs.existsSync(script)) {
      const child = spawn(
        process.execPath,
        [script, cfg.recallHost, cfg.recallApiKey || ""],
        { detached: true, stdio: "ignore" },
      );
      child.unref();
    }
  } catch (_) {}
  return dim("○");
}

function gitSegment(cwd) {
  try {
    const branch = execSync("git rev-parse --abbrev-ref HEAD", {
      cwd,
      stdio: "pipe",
      timeout: 2000,
    }).toString().trim();
    const dirty = execSync("git status --porcelain", {
      cwd,
      stdio: "pipe",
      timeout: 2000,
    }).toString().trim();
    const name = branch.length > 20 ? branch.slice(0, 20) : branch;
    return dim(name) + (dirty ? c("amber", "*") : "");
  } catch (_) {
    return "";
  }
}

function buildSegment(cwd) {
  try {
    // Read autopilot mode
    const modeFile = path.join(cwd, ".autopilot", "mode");
    if (!fs.existsSync(modeFile)) return "";
    const mode = fs.readFileSync(modeFile, "utf8").trim();
    if (!mode) return "";

    // Read progress.json for task counts and wave
    const progressFile = path.join(cwd, ".autopilot", "progress.json");
    if (!fs.existsSync(progressFile)) {
      // Mode file exists but no progress yet (e.g. plan mode)
      return c("amber", `\u2699 ${mode}`);
    }
    const data = JSON.parse(fs.readFileSync(progressFile, "utf8"));
    const tasks = data.tasks || [];
    const done = tasks.filter((t) => t.status === "DONE").length;
    const total = tasks.length;

    // Wave: pull from progress.json if present, else count from questions.md
    const wave = data.wave || null;
    const waveStr = wave ? ` \u00b7 wave ${wave}` : "";

    const taskStr = total > 0 ? ` \u00b7 ${done}/${total}` : "";
    const modeCol = mode === "build" ? "amber" : mode === "fix" ? "pink" : mode === "verify" ? "cyan" : "orange";
    return c(modeCol, `\u2699 ${mode}${waveStr}${taskStr}`);
  } catch (_) {
    return "";
  }
}

function uiSegment(cwd) {
  try {
    const p = path.join(cwd, ".ui", "mode");
    if (!fs.existsSync(p)) return "";
    const mode = fs.readFileSync(p, "utf8").trim();
    if (!mode) return "";
    return c("cyan", `ui:${mode}`);
  } catch (_) {
    return "";
  }
}

function recallSegment(sessionId) {
  if (!sessionId) return "";
  try {
    const counterFile = path.join(os.tmpdir(), `masonry-recall-hits-${sessionId}.txt`);
    if (!fs.existsSync(counterFile)) return "";
    const val = parseInt(fs.readFileSync(counterFile, "utf8").trim(), 10);
    if (!val || val <= 0) return "";
    return `\x1b[2m\x1b[38;2;34;211;238m↑${val} mem\x1b[0m`;
  } catch (_) {
    return "";
  }
}

function claimsSegment(cwd) {
  try {
    const p = path.join(cwd, ".autopilot", "claims.json");
    if (!fs.existsSync(p)) return "";
    const claims = JSON.parse(fs.readFileSync(p, "utf8"));
    if (!Array.isArray(claims)) return "";
    const pending = claims.filter((c) => c.status === "pending").length;
    if (pending === 0) return "";
    return c("amber", `\u26a0 ${pending} claim${pending === 1 ? "" : "s"}`);
  } catch (_) {
    return "";
  }
}

function agentsSegment(state) {
  // Primary: state.active_agents array from masonry-state.json
  if (state && state.active_agents && Array.isArray(state.active_agents) && state.active_agents.length > 0) {
    const names = state.active_agents.slice(0, 3).join(" · ");
    const extra = state.active_agents.length > 3 ? ` +${state.active_agents.length - 3}` : "";
    return c("purple", `⟳ ${names}${extra}`);
  }
  // Fallback: active_agent string + optional count from subagent-tracker writes
  if (state && state.active_agent) {
    const count = state.active_agent_count || 1;
    return count > 1
      ? c("purple", `⟳ ${state.active_agent} +${count - 1}`)
      : c("purple", `⟳ ${state.active_agent}`);
  }
  return "";
}

function agentsFileSegment(sessionId) {
  try {
    const agentsFile = path.join(os.homedir(), ".masonry", "state", "agents.json");
    if (!fs.existsSync(agentsFile)) return "";
    const data = JSON.parse(fs.readFileSync(agentsFile, "utf8"));
    const active = data.active || [];
    const now = Date.now();
    // Only consider agents started in the last 10 minutes
    const fresh = active.filter((a) => now - (a.startedAt || 0) < 600_000);
    if (fresh.length === 0) return "";

    // Prefer agents matching this session; fall back to all fresh agents
    const relevant = sessionId
      ? fresh.filter((a) => a.sessionId === sessionId)
      : fresh;
    const display = relevant.length > 0 ? relevant : fresh;

    if (display.length === 0) return "";
    // Show up to 2 names, then "+N more"
    // Color: dim gray for general-purpose (fallback), purple for specialists
    const isGeneric = display.every((a) => a.name === "general-purpose" || a.name === "agent");
    const names = display.slice(0, 2).map((a) => a.name).join(" · ");
    const extra = display.length > 2 ? ` +${display.length - 2}` : "";
    return isGeneric
      ? dim(`⟳ ${names}${extra}`)
      : c("purple", `⟳ ${names}${extra}`);
  } catch (_) {
    return "";
  }
}

// Parse questions.md to get accurate q_total, q_done, and wave number.
// Handles three formats:
//   BL1 heading:  ### Q1            with **Status**: DONE below
//   BL2 heading:  ### D1.1, E1.1    with **Status**: DONE below
//   BL2 table:    | E1.1 | evolve | DONE | ...question... |
function parseQuestionsFile(cwd) {
  try {
    const qf = path.join(cwd, "questions.md");
    if (!fs.existsSync(qf)) return { q_total: 0, q_done: 0, wave: 0 };
    const lines = fs.readFileSync(qf, "utf8").split("\n");
    let q_total = 0;
    let q_done = 0;
    let wave = 0;
    for (const line of lines) {
      if (/^##\s+Wave\s+\d/i.test(line)) wave++;

      // BL2 heading format: ### D1.1, ### A1.1, ### E1.1, ### Q1
      if (/^###\s+([A-Z]\d+(\.\d+)?|Q\d+)/i.test(line)) {
        q_total++;
        continue;
      }

      // BL2 table row format: | E1.1 | mode | STATUS | question text |
      // Skip header/separator rows (header has "ID", separator has dashes)
      const tableMatch = line.match(/^\|\s*([A-Za-z]\d+\.\d+|Q\d+(\.\d+)?)\s*\|[^|]+\|\s*(\w+)\s*\|/);
      if (tableMatch) {
        q_total++;
        const status = tableMatch[3].toUpperCase();
        if (status === "DONE" || status === "INCONCLUSIVE") q_done++;
        continue;
      }

      // BL1/BL2 heading status field
      if (/^\*\*Status\*\*:\s*(DONE|INCONCLUSIVE)/i.test(line)) q_done++;
    }
    return { q_total, q_done, wave };
  } catch (_) {
    return { q_total: 0, q_done: 0, wave: 0 };
  }
}

// Read stdin synchronously — cross-platform (fd 0 works on Windows + Unix)
let stdinData = "";
try {
  const buf = Buffer.allocUnsafe(65536);
  const n = fs.readSync(0, buf, 0, buf.length, null);
  stdinData = buf.slice(0, n).toString("utf8");
} catch (_) {}
let input = {};
try {
  input = JSON.parse(stdinData);
} catch (_) {}

const ctxPct = Math.round(input.context_window?.used_percentage || 0);
const cfg = loadConfig();
const cwd = input.cwd || process.env.CLAUDE_PROJECT_DIR || process.cwd();
const sessionId = input.session_id || process.env.CLAUDE_SESSION_ID || "";
const brand = `🧱  ${c("purple", "masonry")}`;

let state = null;
try {
  const sf = path.join(cwd, "masonry-state.json");
  if (fs.existsSync(sf)) state = JSON.parse(fs.readFileSync(sf, "utf8"));
} catch (_) {}

const project = (state && state.project) || path.basename(cwd);
const bar = progressBar(ctxPct);
const ctxStr =
  ctxPct >= 65
    ? c("pink", `${ctxPct}%`)
    : ctxPct >= 40
      ? c("orange", `${ctxPct}%`)
      : c("purple", `${ctxPct}%`);
const recall = recallDot(cfg);

if (!state) {
  const bldSeg = buildSegment(cwd);
  const agentSeg = agentsFileSegment(sessionId);
  const claimsSeg = claimsSegment(cwd);
  process.stdout.write(
    [
      brand,
      sep,
      dim(project),
      sep,
      gitSegment(cwd),
      recallSegment(sessionId),
      bldSeg,
      agentSeg,
      claimsSeg,
      uiSegment(cwd),
      sep,
      bldSeg ? "" : dim("no campaign · /masonry-run to start"),
      sep,
      `${bar} ${ctxStr}`,
      sep,
      `${recall} ${dim("recall")}`,
    ]
      .filter(Boolean)
      .join("  ") + "\n",
  );
  process.exit(0);
}

const {
  last_qid = "",
  verdicts = {},
} = state;

// Derive mode label: prefer state.mode, else infer from last_qid prefix (D=diagnose, A=validate, R=research)
const modeMap = { D: "diagnose", A: "validate", R: "research", V: "validate", F: "fix", E: "evolve", M: "monitor" };
const qidPrefix = last_qid ? last_qid[0].toUpperCase() : "";
const mode = state.mode || modeMap[qidPrefix] || (last_qid ? "research" : "?");

// Get totals from questions.md — more accurate than state fields
const { q_total, q_done, wave } = parseQuestionsFile(cwd);
const fixCount = (verdicts.FIX_APPLIED || 0) + (verdicts.FIX_COMPLETE || 0) + (verdicts.CLEARED || 0);
const v = [
  verdicts.HEALTHY > 0 ? c("green", `✓${verdicts.HEALTHY}`) : "",
  verdicts.IMPROVEMENT > 0 ? c("green", `↑${verdicts.IMPROVEMENT}`) : "",
  fixCount > 0 ? c("cyan", `⚡${fixCount}`) : "",
  verdicts.WARNING > 0 ? c("amber", `⚠${verdicts.WARNING}`) : "",
  verdicts.FAILURE > 0 ? c("red", `✗${verdicts.FAILURE}`) : "",
  verdicts.REGRESSION > 0 ? c("red", `↓${verdicts.REGRESSION}`) : "",
]
  .filter(Boolean)
  .join(" ");

// Priority: active build > active agents > campaign mode label
const bldSeg = buildSegment(cwd);
const agentsSeg = agentsSegment(state) || agentsFileSegment(sessionId);
const campaignLabel = bldSeg || agentsSeg || c("cyan", `${mode} · wave ${wave}`);

process.stdout.write(
  [
    brand,
    sep,
    dim(project),
    campaignLabel,
    sep,
    q_total > 0 ? `Q${q_done}/${q_total}` : "",
    campaignLabel === agentsSeg ? "" : agentsSeg,
    claimsSegment(cwd),
    sep,
    gitSegment(cwd),
    recallSegment(sessionId),
    uiSegment(cwd),
    sep,
    `${bar} ${ctxStr}`,
    v,
    sep,
    `${recall} ${dim("recall")}`,
  ]
    .filter(Boolean)
    .join("  ") + "\n",
);
process.exit(0);
